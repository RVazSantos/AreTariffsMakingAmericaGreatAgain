        <zone flipboard-zone-id='5' forceUpdate='true' h='19191' id='6' story-point-id='1' type-v2='text' w='92618' x='3248' y='16390'>
          <formatted-text>
            <run bold='true' fontname='Tableau Medium'>Executive Order. Country based tariffs:</run>
            <run>Æ&#10;&#10;</run>
            <run fontname='Tableau Medium'>Canada: 25%</run>
            <run>Æ&#10;</run>
            <run fontname='Tableau Medium'>Mexico: 25%</run>
            <run>Æ&#10;</run>
            <run fontname='Tableau Medium'>China: 10%</run>
            <run>&#10;&#10;Paused on February 3&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='15456' hidden='true' id='7' story-point-id='2' type-v2='text' w='99902' x='-98' y='17739'>
          <formatted-text>
            <run bold='true' fontname='Tableau Medium'>Previous proclamation goes into effect. </run>
            <run>Æ&#10;</run>
            <run bold='true' fontname='Tableau Medium'>Automobiles:</run>
            <run>Æ&#10;&#10;</run>
            <run fontname='Tableau Medium'>All: 25%</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='15456' hidden='true' id='8' story-point-id='3' type-v2='text' w='99902' x='-98' y='17739'>
          <formatted-text>
            <run bold='true' fontname='Tableau Medium'>Previous proclamation goes into effect. </run>
            <run>Æ&#10;</run>
            <run bold='true' fontname='Tableau Medium'>Auto parts:</run>
            <run>Æ&#10;&#10;</run>
            <run fontname='Tableau Medium'>All countries: 25%</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='15456' hidden='true' id='9' story-point-id='4' type-v2='text' w='99902' x='-98' y='17012'>
          <formatted-text>
            <run bold='true' fontname='Tableau Medium'>Previous proclamation goes into effect.  </run>
            <run>Æ&#10;</run>
            <run bold='true' fontname='Tableau Medium'>Copper articles and derivative products:</run>
            <run>Æ&#10;&#10;</run>
            <run fontname='Tableau Medium'>All countries: 50%</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='15456' hidden='true' id='10' story-point-id='5' type-v2='text' w='99902' x='-98' y='17739'>
          <formatted-text>
            <run bold='true' fontname='Tableau Medium'>Previous proclamation goes into effect. </run>
            <run>Æ&#10;</run>
            <run bold='true' fontname='Tableau Medium'>Timber, lumber and derivative products:</run>
            <run>Æ&#10;&#10;</run>
            <run fontname='Tableau Medium'>UK: 10%</run>
            <run>Æ&#10;</run>
            <run fontname='Tableau Medium'>Others: 25%</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='15456' hidden='true' id='11' story-point-id='6' type-v2='text' w='99902' x='-98' y='16598'>
          <formatted-text>
            <run bold='true' fontname='Tableau Medium'>Previous proclamation goes into effect. </run>
            <run>Æ&#10;</run>
            <run bold='true' fontname='Tableau Medium'>Trucks and truck parts:</run>
            <run>Æ&#10;&#10;</run>
            <run fontname='Tableau Medium'>All countries: 10-25%</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='15456' hidden='true' id='13' story-point-id='8' type-v2='text' w='99902' x='-98' y='17739'>
          <formatted-text>
            <run bold='true' fontname='Tableau Medium'>Executive Order for reciprocal tariffs</run>
            <run>Æ&#10;&#10;</run>
            <run fontname='Tableau Medium'>Each country with it&apos;s own tariff percentage. Suspended on the following day. 10% applied to all countries, except China (34%)</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='15456' hidden='true' id='15' story-point-id='10' type-v2='text' w='99902' x='0' y='15249'>
          <formatted-text>
            <run bold='true' fontname='Tableau Medium'>Tariffs on China lowered to 10%</run>
            <run>Æ&#10;&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='14627' hidden='true' id='16' story-point-id='11' type-v2='text' w='98031' x='1969' y='18880'>
          <formatted-text>
            <run bold='true' fontname='Tableau Medium'>Previous proclamation goes into effect.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontname='Tableau Medium'>Aluminum and Steel articles and derivative products:</run>
            <run>Æ&#10;&#10;</run>
            <run fontname='Tableau Medium'>Russia: 200%</run>
